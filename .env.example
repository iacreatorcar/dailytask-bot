# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot token (create a bot via @BotFather)
TELEGRAM_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your name (used in Telegram morning digest)
USER_NAME=YourName

# Server port
PORT=3000

# Path to your CV folder (optional)
CV_PATH=/home/youruser/Desktop/cv

# Gmail IMAP (requires an App Password, NOT your regular password)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
